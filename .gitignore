# Этот файл определяет, какие файлы и папки Git должен игнорировать
# при работе с репозиторием. Это позволяет не включать в репозиторий
# временные, конфиденциальные или генерируемые автоматически файлы.

# ==================== Системные файлы ====================

# Файлы, создаваемые операционной системой
.DS_Store           # macOS: служебный файл для хранения атрибутов папок
Thumbs.db           # Windows: кэш миниатюр
desktop.ini         # Windows: файл настроек папки
*.swp               # Vim: временные файлы
*.swo               # Vim: временные файлы
*~                  # Резервные копии, создаваемые некоторыми редакторами

# ==================== Среда разработки и IDE ====================

# PyCharm (IntelliJ IDEA)
.idea/
*.iml
*.iws

# Visual Studio Code
.vscode/
*.code-workspace

# Eclipse
.project
.classpath
.settings/

# NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# ==================== Кэш и временные файлы Python ====================

__pycache__/                # Скомпилированные байт-код файлы (.pyc, .pyo)
*.pyc
*.pyo
*.pyd                       # Библиотеки Python для Windows
.pytest_cache/               # Кэш pytest
.mypy_cache/                 # Кэш mypy (статический анализатор)
.ruff_cache/                 # Кэш ruff (линтер)
*.egg-info/                  # Метаданные пакетов
*.egg
dist/                        # Сборки пакетов (для распространения)
build/                       # Временные файлы сборки
pip-wheel-metadata/          # Метаданные колес pip

# ==================== Виртуальные окружения ====================

venv/
env/
.env/
.venv/
ENV/
env.bak/
venv.bak/
pythonenv*                   # Виртуальные окружения, создаваемые некоторыми IDE

# ==================== Базы данных и логи ====================

# База данных SQLite (основная БД проекта)
megevoy.db
megevoy.db-journal          # Журнал транзакций SQLite (опционально)
*.sqlite3
*.sqlite

# Лог-файлы приложения
logs/
*.log

# ==================== Входные и выходные данные ====================

# Папки с пользовательскими данными (можно исключить, если они не должны быть в репозитории)
data/
uploads/
exports/

# Временные файлы, создаваемые при экспорте/импорте
*.tmp
*.temp

# Файлы с координатами (пользовательские, могут содержать конфиденциальную информацию)
*.csv
*.kml
*.kmz
*.shp
*.shx
*.dbf
*.prj

# XML-файлы, сгенерированные приложением (не храним в репозитории, так как они создаются пользователем)
*.xml

# PDF-файлы (будут генерироваться позже)
*.pdf

# ZIP-архивы пакетов
*.zip

# ==================== Файлы конфигурации с секретами ====================

# Файлы, которые могут содержать пароли, токены или другую чувствительную информацию
.env.local
.env.development
.env.test
.env.production
secrets.py
config_local.py
*.key
*.pem

# ==================== Тестовые и временные файлы ====================

# Временные файлы, создаваемые тестами
test_output/
htmlcov/                     # Отчёты о покрытии кода (coverage)
.coverage
.coverage.*
*.cover
coverage.xml
*.pytest_cache
*_cache/

# ==================== Сторонние библиотеки и зависимости ====================

# Обычно папка site-packages не включается, если используется виртуальное окружение,
# но иногда разработчики случайно коммитят её. Исключим на всякий случай.
lib/
lib64/
Lib/
Lib64/
site-packages/

# ==================== Файлы проекта, которые нужно исключить ====================

# Если у вас есть папка с пользовательскими проектами внутри репозитория,
# её тоже можно исключить, но это индивидуально.
# user_projects/

# ==================== Документация, генерируемая автоматически ====================

docs/_build/
docs/build/
docs/html/
sphinx/_build/

# ==================== Файлы упаковки и дистрибуции ====================

*.tar.gz
*.whl

# ==================== Прочее ====================

# Файлы, создаваемые инструментами для проверки кода
.tox/                        # Tox (тестирование в нескольких окружениях)
.mxproject                   # Для микроконтроллеров (если вдруг)
.hypothesis/                 # Кэш Hypothesis (генеративное тестирование)

# Файлы резервных копий, создаваемые некоторыми программами
*.bak
*.old
*.orig

# Файлы, содержащие временные метки или pid-процессов
*.pid
*.lock
